# === Core ===
APP_ENV=dev
LOG_LEVEL=DEBUG
API_HOST=0.0.0.0
API_PORT=8000
UI_BASE_URL=http://localhost:5173

# === Database ===
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/jobbot
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/jobbot

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === File Storage ===
ARTIFACT_DIR=./storage/artifacts
PROFILE_DIR=./storage/profiles

# Artifact storage: local (default) | gcs
ARTIFACT_STORAGE_PROVIDER=local
# GCS (only when ARTIFACT_STORAGE_PROVIDER=gcs):
GCS_ARTIFACT_BUCKET=
GCS_PROJECT_ID=
GCS_PREFIX=resumes
GCS_SIGNED_URL_TTL_SECONDS=900

# === Scraper Defaults ===
DEFAULT_SEARCH_QUERY=backend engineer fintech
DEFAULT_LOCATION=New York, NY
SCRAPE_HOURS_OLD=48
SCRAPE_RESULTS_WANTED=50

# === Feature Flags (scrapers / connectors) ===
JOBSPY_ENABLED=true
GREENHOUSE_ENABLED=true
LEVER_ENABLED=true
ASHBY_ENABLED=true
URL_INGEST_ENABLED=true
TRUEUP_ENABLED=false
UNDERDOG_ENABLED=false
STARTUPJOBS_NYC_ENABLED=true
TECHNYC_ENABLED=true
PRIMARY_VC_ENABLED=true
GREYCROFT_ENABLED=true
USV_ENABLED=true
VENTURELOOP_ENABLED=false
BUILTIN_NYC_ENABLED=true
WELCOME_TO_THE_JUNGLE_ENABLED=true
LINKEDIN_JOBS_ENABLED=false
WELLFOUND_ENABLED=false
YC_ENABLED=false

# === Discovery (AGG-1 / SERP) ===
ENABLE_AGG1_DISCOVERY=false
ENABLE_SERP1_DISCOVERY=false
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=us

# === Apollo (optional enrichment) ===
APOLLO_API_KEY=

# === ScrapeOps (only if using Scrapy LinkedIn — not V1) ===
SCRAPEOPS_API_KEY=

# === Auth-board acquisition backend (bb-browser) ===
BB_BROWSER_ENABLED=false
BB_BROWSER_BASE_URL=http://127.0.0.1:9223
BB_BROWSER_CAPTURE_PATH=/session/acquire
BB_BROWSER_API_KEY=
BB_BROWSER_TIMEOUT_MS=45000
BB_BROWSER_CONNECT_TIMEOUT_MS=5000
BB_BROWSER_SESSION_NAME=jobbot-ingestion
BB_BROWSER_VERIFY_SSL=true

# === Auto-generation gate ===
ENABLE_AUTO_RESUME_GENERATION=false
GENERATION_CANONICAL_SCORE_THRESHOLD=60.0
GENERATION_DISCOVERY_SCORE_THRESHOLD=70.0
GENERATION_DISCOVERY_CONFIDENCE_MIN=0.7

# === Push Notifications ===
PUSH_PROVIDER=pushover
PUSHOVER_TOKEN=
PUSHOVER_USER=
NTFY_TOPIC_URL=

# === Resume (grounded inventory path) ===
EXPERIENCE_INVENTORY_PATH=./data/experience_inventory.yaml
MASTER_SKILLS_PATH=./storage/master_skills.json

# === Playwright (PDF resume rendering; v1 always headless) ===
PLAYWRIGHT_TIMEOUT_MS=30000

# === Debug (local/dev only; never enable in production) ===
# DEBUG_ENDPOINTS_ENABLED=false
